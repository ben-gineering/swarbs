{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock", "calendar"],
    "modules-right": ["pulseaudio", "network", "battery", "tray"],
    "sway/workspaces": {
        "format": "{name}",
        "format-focused": "{name}",
        "all-outputs": false,
        "wrap-scroll": true
