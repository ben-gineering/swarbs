            "weekdays": "<span color='#ffcc6c'><b>{}</b></span>",
            "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
        },
        "today-format": "<span color='#ff6699'><b><u>{}</u></b></span>",
        "weeks-position": 1,
        "on-scroll": 1,
        "on-click-right": "mode",
        "on-click": "shift_left",
        "on-click-down": "shift_up",
        "on-click-up": "shift_down"
